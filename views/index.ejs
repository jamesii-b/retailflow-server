<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Statement</title>
    <script src="https://cdn.jsdelivr.net/npm/@popperjs/core@2.11.8/dist/umd/popper.min.js"
        integrity="sha384-I7E8VVD/ismYTF4hNIPjVp/Zjvgyol6VFvRkX/vR+Vc4jQkC+hVqc2pM8ODewa9r"
        crossorigin="anonymous"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.min.js"
        integrity="sha384-BBtl+eGJRgqQAUMxJ7pMwbEyER4l1g+O15P+16Ep7Q9Q+zqX6gSbd85u4mG4QzX+"
        crossorigin="anonymous"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Oswald:wght@200&display=swap" rel="stylesheet">
    <style>
        .home {
            padding: 20px;
            font-size: 17px;
        }

        @media print {
            .myDiv {
                break-inside: avoid;
            }
        }

        #table {
            margin: 20px;
            text-align: center;
        }

        .table {
            width: 100%;
            border-collapse: collapse;
            margin-bottom: 20px;
            overflow-x: auto;
            /* Enable horizontal scrolling on small screens */
        }

        th,
        td {
            border: 1px solid #ddd;
            padding: 8px;
            text-align: left;
        }

        th {
            background-color: #f2f2f2;
        }

        /* Media query for smaller screens */
        @media screen and (max-width: 600px) {

            th,
            td {
                font-size: 12px;
                /* Adjust font size for small screens */
            }
        }

        #infoBox {
            padding: 20px;
            padding-right: 100px;
            border-radius: 20px;
            display: inline-block;
            margin-bottom: 20px;
            background-color: rgb(239, 239, 234);
        }

        .null {
            height: 20;
        }

        .title {
            text-align: center;
        }

        .footer>.box {
            background-color: rgb(180, 180, 216);
            margin-top: 0;
            padding: 20px;
            border-radius: 10px;
            display: flex;
            justify-content: space-around;
            flex-wrap: wrap;
            /* Allow items to wrap to the next line if needed */
        }

        .footer>.box>.text {
            text-align: center;
        }

        .footer .values {
            text-align: center;
            width: 100%;
            display: flex;
            justify-content: space-around;
        }

        .footer .values>div {
            width: 100%;
            /* Ensure each value takes full width */
        }

        .footer>.box>.field>.text {
            font-weight: 600;
        }
    </style>
</head>

<body>
    <div class="home">

        <div class="header">
            <div class="title">
                <div class="text" style="font-size: 30px;font-weight: 500;">
                    CaveTown Mart
                    <br>
                    <span style="font-size: 17px;" id="address">Tokha, Kathmandu</span>
                </div>
            </div>
        </div>
        <br>
        <h1 class="sub-title">
            Statement of <%=title%>
        </h1>
        <div id="infoBox">
            <div id="from">
                FROM: <%=fromDate%>
            </div>
            <div id="To">
                TO: <%=toDate%>
            </div>
            <div id="current_date">
                CURRENT DATE: <%=currentDate%>
            </div>
        </div>

        <div id="table">
            <table class="table table-bordered border-primary">
                <thead>
                    <tr>
                        <td style="font-weight: 600;">Date</td>
                        <td style="font-weight: 600;">Description</td>
                        <td style="font-weight: 600;">Debit</td>
                        <td style="font-weight: 600;">Credit</td>
                        <td style="font-weight: 600;">Balance</td>
                    </tr>
                </thead>
                <tbody>

                    <% for (const element of orders){ %>
                        <tr>
                            <td>
                                <%= new Date(element[0]) %>
                            </td>
                            <td>
                                <%= element[1] %>
                            </td>
                            <td>
                                <%= element[2] %>
                            </td>
                            <td>
                                <%= element[3] %>
                            </td>
                            <td>
                                <%= element[4] %>
                            </td>

                        </tr>
                        <% }; %>
                </tbody>
            </table>
        </div>


        <div class="footer">
            <div class="text" style="font-weight: 600;">
                Transaction Summary
            </div>

            <div class="box">
                <div class="field">
                    <div class="text">
                        Opening Balance:
                    </div>
                    <!-- <div class="value">
                        260000
                    </div> -->
                </div>
                <div class="field">
                    <div class="text">
                        Dr. Entry:
                    </div>
                    <!-- <div class="value">
                        10000
                    </div> -->
                </div>
                <div class="field">
                    <div class="text">
                        Cr. Entry:
                    </div>
                    <!-- <div class="value">
                        2600131300
                    </div> -->
                </div>
                <div class="field">
                    <div class="text">
                        Closing Balance:
                    </div>
                    <!-- <div class="value">
                        314440
                    </div> -->
                </div>
            </div>
        </div>


    </div>
</body>

</html>